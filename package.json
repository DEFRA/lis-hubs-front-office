{
  "name": "@livestock/hub-front-office",
  "private": true,
  "version": "0.1.0",
  "description": "Front-office hub application for the livestock platform.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "build:frontend": "vite build",
    "predev": "npm run build:frontend",
    "dev": "AWS_EMF_ENVIRONMENT=Local npm run server:watch",
    "dev:debug": "AWS_EMF_ENVIRONMENT=Local npm run server:debug",
    "dev:debug:ide": "AWS_EMF_ENVIRONMENT=Local npm run server:debug:ide",
    "docker:dev": "npm run dev",
    "format": "prettier --write \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js}\"",
    "git:pre-commit-hook": "npm run security-audit && npm run format:check && npm run lint && npm test",
    "lint": "run-s lint:js lint:scss",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:scss": "stylelint \"src/**/*.scss\" --cache --cache-location .cache/stylelint --cache-strategy content --color --ignore-path .gitignore",
    "test": "AWS_EMF_ENVIRONMENT=Local TZ=UTC vitest run --coverage",
    "test:watch": "AWS_EMF_ENVIRONMENT=Local TZ=UTC vitest",
    "security-audit": "npm audit --audit-level=critical",
    "server:watch": "nodemon --inspect=0 --ext js,json --legacy-watch --watch ./src/server --watch ./src/config --env-file-if-exists=.env ./src",
    "server:debug": "nodemon --inspect-brk=0 --ext js,json --legacy-watch --watch ./src/server --watch ./src/config --env-file-if-exists=.env ./src",
    "server:debug:ide": "node --inspect=0 --use-system-ca --env-file-if-exists=.env ./src",
    "prestart": "npm run build:frontend",
    "start": "NODE_ENV=production node .",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module"
  },
  "imports": {
    "#*": "./src/*"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@hapi/inert": "7.1.0",
    "@hapi/hapi": "21.4.8",
    "@hapi/scooter": "8.0.0",
    "@livestock/hubs-infra-core": "^0.1.0",
    "@livestock/hubs-infra-registry": "^0.1.0",
    "@livestock/ui-services": "^0.1.0",
    "blankie": "5.0.0",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "govuk-frontend": "6.1.0"
  },
  "devDependencies": {
    "@babel/preset-env": "7.29.2",
    "@defra/hapi-connect": "1.0.1",
    "@vitest/coverage-v8": "4.1.4",
    "cheerio": "1.2.0",
    "eslint": "9.39.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "husky": "9.1.7",
    "neostandard": "0.13.0",
    "nodemon": "3.1.14",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.2",
    "sass-embedded": "1.99.0",
    "stylelint": "16.26.1",
    "stylelint-config-gds": "2.0.0",
    "vite": "8.0.8",
    "vitest": "4.1.4",
    "vitest-fetch-mock": "0.4.5"
  }
}
